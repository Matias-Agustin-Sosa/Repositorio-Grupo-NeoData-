<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NeoData Shop</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">NeoData Shop</span>
            <button class="btn btn-outline-light" data-bs-toggle="modal" data-bs-target="#modalCarrito">
                🛒 Carrito (<span id="cart-count">0</span>)
            </button>
        </div>
    </nav>
    
    <div class="container mt-5" id="app">
        <h2>Catálogo de Productos</h2>
        <div class="row mt-4" id="catalogo">
            
            <% productos.forEach((producto) => { %>
                <div class="col-12 col-md-6 col-lg-3 mb-4"> 
                    <div class="card h-100 position-relative"> 
                        <span class="position-absolute top-0 end-0 badge rounded-pill bg-danger m-2">
                            <%= producto.descuento %>
                        </span>

                        <img src="<%= producto.imagen %>" class="card-img-top" alt="<%= producto.nombre %>">

                        <div class="card-body d-flex flex-column"> 
                            <h5 class="card-title"><%= producto.nombre %></h5>
                            <h6 class="card-subtitle mb-2 text-primary">$<%= producto.precio.toLocaleString() %></h6>
                            
                            <p class="card-text text-muted small">
                                Esta es una descripción breve del producto.
                            </p>

                            <div class="mt-auto"> 
                                <div class="input-group mb-3">
                                    <button class="btn btn-outline-secondary btn-sm btn-restar" type="button">-</button>
                                    <input type="text" class="form-control form-control-sm text-center input-cantidad" value="1" readonly>
                                    <button class="btn btn-outline-secondary btn-sm btn-sumar" type="button">+</button>
                                </div>

                                <div class="d-grid">
                                    <button class="btn btn-primary btn-sm" onclick="seleccionarProducto('<%= producto.nombre %>', <%= producto.precio %>, this)">
                                        Añadir al carrito
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>

        </div>
    </div>

    <div class="modal fade" id="modalCarrito" tabindex="-1" aria-labelledby="modalCarritoLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title" id="modalCarritoLabel">🛒 Detalle de tu Compra</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Precio Unit.</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody id="tabla-carrito">
                            <tr>
                                <td colspan="4" class="text-center text-muted py-3">El carrito está vacío.</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <hr>
                    
                    <div class="d-flex justify-content-between align-items-center mt-3 px-2">
                        <h4 class="mb-0">Total a Abonar:</h4>
                        <h3 class="text-success mb-0 font-weight-bold">$<span id="total-abonar">0</span></h3>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-danger" onclick="vaciarCarrito()">Vaciar Carrito</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Seguir Comprando</button>
                    <button type="button" class="btn btn-success" onclick="finalizarCompra()">Iniciar Pago</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    <script>
        // PERSISTENCIA: Al iniciar, intentamos recuperar los datos previos de LocalStorage [cite: 123]
        const carritoGuardado = localStorage.getItem('carrito');
        let carrito = carritoGuardado ? JSON.parse(carritoGuardado) : [];

        // Pintamos el estado actual guardado por si el usuario hizo F5
        actualizarInterfazCarrito();

        // Escuchador dinámico para botones de incremento y decremento
        document.getElementById('catalogo').addEventListener('click', function(event) {
            if (event.target.classList.contains('btn-sumar')) {
                const input = event.target.previousElementSibling;
                let cantidad = parseInt(input.value);
                input.value = cantidad + 1;
            }

            if (event.target.classList.contains('btn-restar')) {
                const input = event.target.nextElementSibling;
                let cantidad = parseInt(input.value);
                if (cantidad > 1) { 
                    input.value = cantidad - 1;
                }
            }
        });

        // Agrega un producto a la memoria del carrito
        function seleccionarProducto(nombre, precio, boton) {
            const tarjetaBody = boton.closest('.card-body');
            const inputCantidad = tarjetaBody.querySelector('.input-cantidad');
            const cantidadSeleccionada = parseInt(inputCantidad.value);

            const productoExistente = carrito.find(item => item.nombre === nombre);

            if (productoExistente) {
                productoExistente.cantidad += cantidadSeleccionada;
            } else {
                carrito.push({
                    nombre: nombre,
                    precio: precio,
                    cantidad: cantidadSeleccionada
                });
            }

            // Guardamos el arreglo actualizado como texto plano en LocalStorage
            localStorage.setItem('carrito', JSON.stringify(carrito));

            // Renderizamos los cambios en pantalla
            actualizarInterfazCarrito();

            // Reseteamos el selector numérico a 1
            inputCantidad.value = 1;
        }

        // Redibuja la tabla dentro del Modal y los contadores numéricos
        function actualizarInterfazCarrito() {
            const tabla = document.getElementById('tabla-carrito');
            const txtTotalAbonar = document.getElementById('total-abonar');
            const txtCartCount = document.getElementById('cart-count');

            if (carrito.length === 0) {
                tabla.innerHTML = `<tr><td colspan="4" class="text-center text-muted py-3">El carrito está vacío.</td></tr>`;
                txtTotalAbonar.innerText = "0";
                txtCartCount.innerText = "0";
                return;
            }

            let htmlFilas = "";
            let totalGeneral = 0;
            let totalItems = 0;

            carrito.forEach(item => {
                const subtotal = item.precio * item.cantidad;
                totalGeneral += subtotal;
                totalItems += item.cantidad;

                htmlFilas += `
                    <tr>
                        <td><strong>${item.nombre}</strong></td>
                        <td class="text-center">$${item.precio.toLocaleString()}</td>
                        <td class="text-center"><span class="badge bg-secondary p-2">${item.cantidad}</span></td>
                        <td class="text-end fw-bold">$${subtotal.toLocaleString()}</td>
                    </tr>
                `;
            });

            tabla.innerHTML = htmlFilas;
            txtTotalAbonar.innerText = totalGeneral.toLocaleString();
            txtCartCount.innerText = totalItems;
        }

        // Limpia el carrito por completo
        function vaciarCarrito() {
            if (confirm("¿Estás seguro de que querés vaciar el carrito?")) {
                carrito = [];
                localStorage.removeItem('carrito');
                actualizarInterfazCarrito();
            }
        }

        // INTEGRACIÓN (FETCH POST): Envía el carrito guardado hacia el Backend [cite: 121, 153]
        async function finalizarCompra() {
            if (carrito.length === 0) {
                alert("El carrito está vacío."); 
                return;
            }

            try { 
                // Hacemos el envío asíncrono en formato JSON [cite: 77, 129, 131]
                const respuesta = await fetch('/api/checkout', { 
                    method: 'POST', 
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(carrito) // Empaquetamos los datos [cite: 132]
                });

                const resultado = await respuesta.json(); 
                alert(resultado.mensaje); // "Ticket generado con éxito..." [cite: 134]

                // Limpieza post-compra exitosa [cite: 135]
                carrito = [];
                localStorage.removeItem('carrito');
                actualizarInterfazCarrito();

                // Escondemos el modal usando Bootstrap
                const modalElement = document.getElementById('modalCarrito');
                const modalInstance = bootstrap.Modal.getInstance(modalElement);
                if (modalInstance) modalInstance.hide();

            } catch (error) {
                console.error("Error en la compra:", error); 
                alert("Ocurrió un error en el servidor.");
            }
        }
    </script>
</body>
</html>