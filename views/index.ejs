<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>NeoData Shop</title>
    
    <!-- Link a Bootstrap 5 (CDN) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <!-- Font Awesome para iconos -->    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body class="bg-light">
    <!-- Barra de Navegación -->
    <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">NeoData Shop</span>
            <button class="btn btn-outline-light">🛒 Carrito (<span id="cart-count">0</span>)</button>
        </div>
    </nav>
    
    <!-- Contenedor Principal -->
    <div class="container mt-5" id="app">
        <h2>Catálogo de Productos</h2>
        <div class="row mt-4" id="catalogo">
            <!-- Las tarjetas (Cards) se generarán aquí -->
            <script>
                // Datos de productos
                const productos = [
                    { nombre: "Smartwatch", precio: 125000, stock: 12, descuento: "5%", imagen: "../Image/Producto.png"},
                    { nombre: "Celular", precio: 350000, stock: 8, descuento: "2%", imagen: "../Image/Producto.png"},
                    { nombre: "Auriculares", precio: 45000, stock: 20, descuento: "7%", imagen: "../Image/Producto.png"},
                    { nombre: "Mouse", precio: 25000, stock: 15, descuento: "3%", imagen: "../Image/Producto.png"}
                ];
                
                // Obtener el contenedor donde se añadirán las cards
                const contenedor = document.getElementById("catalogo");
                let htmlCards = "";

                // Iterar sobre los productos
                productos.forEach((producto, index) => {
                    // Construir la plantilla HTML
                    // Dentro de tu productos.forEach:
                    const cardHTML = `
                        <div class="col-12 col-md-6 col-lg-3"> <div class="card h-100 position-relative"> <span class="position-absolute top-0 end-0 badge rounded-pill bg-danger m-2">
                                    ${producto.descuento}
                                </span>

                                <img src="/Producto.png" class="card-img-top" alt="Producto">

                                <div class="card-body d-flex flex-column"> <h5 class="card-title">${producto.nombre}</h5>
                                    <h6 class="card-subtitle mb-2 text-primary">$${producto.precio.toLocaleString()}</h6>
                                    
                                    <p class="card-text text-muted small">
                                        Esta es una descripción breve del producto.
                                    </p>

                                    <div class="mt-auto"> <div class="input-group mb-3">
                                            <button class="btn btn-outline-secondary btn-sm" type="button">-</button>
                                            <input type="text" class="form-control form-control-sm text-center" value="1" readonly>
                                            <button class="btn btn-outline-secondary btn-sm" type="button">+</button>
                                        </div>

                                        <div class="d-grid">
                                            <button class="btn btn-primary btn-sm" onclick="seleccionarProducto('${producto.nombre}', ${producto.precio})">
                                                Añadir al carrito
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                    htmlCards += cardHTML;
                });

                // Insertar todo el HTML generado en el contenedor
                contenedor.innerHTML = htmlCards;

                // Función para manejar la selección de productos
                let carritoCount = 0;
                
                function seleccionarProducto(nombre, precio) {
                    carritoCount++;
                    document.getElementById('cart-count').innerText = carritoCount;
                    console.log(`Producto seleccionado: ${nombre} - $${precio.toLocaleString()}`);
                    alert(`Has añadido ${nombre} al carrito. Total en carrito: ${carritoCount} producto(s)`);
                }
            </script>
        </div>
    </div>

</body>
</html>