<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NeoData Shop</title>
    <link rel="icon" type="image/png" href="Logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        .card-dinamica { transition: transform 0.2s; }
        .card-dinamica:hover { transform: scale(1.02); }
    </style>
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">NeoData Shop</a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="d-flex align-items-center ms-auto gap-2 py-2 py-lg-0">
                    
                    <div id="admin-actions" class="d-flex align-items-center"></div>

                    <button class="btn btn-outline-light d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#modalCarrito">
                        <i class="bi bi-cart3 fs-5"></i>
                        <span>Ver Carrito</span>
                        <span class="badge bg-danger" id="contador-carrito">0</span>
                    </button>

                    <div id="session-actions" class="d-flex align-items-center">
                        <button class="btn btn-outline-light d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#authModal">
                            <i class="bi bi-person-circle fs-5"></i>
                            <span>Mi Cuenta</span>
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <h2 class="text-center mb-4 fw-bold text-secondary">Nuestro Catálogo</h2>
        
        <div class="row justify-content-center mb-4">
            <div class="col-12 col-md-4">
                <label for="category-filter" class="form-label fw-bold text-muted small">Filtrar por Categoría:</label>
                <select id="category-filter" class="form-select shadow-sm" onchange="loadProducts(this.value, 1)">
                    <option value="">Todas las categorías</option>
                    <option value="Componentes">Componentes</option>
                    <option value="Periféricos">Periféricos</option>
                    <option value="Celulares">Celulares</option>
                </select>
            </div>
        </div>
        
        <div class="row mt-2" id="catalogo-contenedor"></div>
    </div>

    <div class="modal fade" id="modalCarrito" tabindex="-1" aria-labelledby="modalCarritoLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title fw-bold" id="modalCarritoLabel"><i class="bi bi-cart3 me-2"></i>Tu Carrito de Compras</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="lista-carrito-vacia" class="text-center text-muted py-4">
                        <i class="bi bi-basket fs-1"></i>
                        <p class="mt-2">El carrito está vacío.</p>
                    </div>
                    <ul class="list-group d-none" id="lista-carrito-productos"></ul>
                    <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top fw-bold fs-5">
                        <span>Total:</span>
                        <span class="text-primary" id="total-carrito">$0</span>
                    </div>
                    <div class="mb-3 p-3 bg-light rounded border">
                        <label for="medio-pago" class="form-label small fw-bold text-secondary"><i class="bi bi-credit-card"></i> Selecciona Medio de Pago:</label>
                        <select id="medio-pago" class="form-select form-select-sm" required>
                            <option value="1">Tarjeta de Débito</option>
                            <option value="2">Tarjeta de Crédito</option>
                        </select>
                        <label for="cupon-carrito" class="form-label small fw-bold text-secondary mt-3"><i class="bi bi-ticket-perforated"></i> Cupon opcional:</label>
                        <input type="number" id="cupon-carrito" class="form-control form-control-sm" min="1" max="2" placeholder="Ej: 10012832">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger me-auto" id="btn-vaciar" onclick="abrirModalConfirmarVaciar()" disabled>
                        <i class="bi bi-trash3 me-1"></i>Vaciar Carrito
                    </button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Seguir Comprando</button>
                    <button type="button" class="btn btn-success fw-bold" id="btn-pagar" onclick="enviarCheckout()" disabled>
                        <i class="bi bi-credit-card me-2"></i>Iniciar Pago
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="authModal" tabindex="-1" aria-labelledby="authModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="authModalLabel">NeoData Shop - Acceso</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <ul class="nav nav-tabs mb-3" id="authTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="login-tab" data-bs-toggle="tab" data-bs-target="#login-panel" type="button" role="tab">Ingresar</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="register-tab" data-bs-toggle="tab" data-bs-target="#register-panel" type="button" role="tab">Registrarse</button>
                        </li>
                    </ul>
                    
                    <div class="tab-content" id="authTabsContent">
                        <div class="tab-pane fade show active" id="login-panel" role="tabpanel">
                            <form id="form-login" onsubmit="ejecutarLogin(event)">
                                <div class="mb-3">
                                    <label class="form-label small">Correo Electrónico</label>
                                    <input type="email" id="login-email" class="form-control" required placeholder="ejemplo@correo.com">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small">Contraseña</label>
                                    <input type="password" id="login-password" class="form-control" required placeholder="******">
                                </div>
                                <button type="submit" class="btn btn-dark w-100">Iniciar Sesión</button>
                            </form>
                        </div>
                        
                        <div class="tab-pane fade" id="register-panel" role="tabpanel">
                            <form id="form-registro" onsubmit="ejecutarRegistro(event)">
                                <div class="row mb-2">
                                    <div class="col">
                                        <label class="form-label small">Nombre</label>
                                        <input type="text" id="reg-nombre" class="form-control" required>
                                    </div>
                                    <div class="col">
                                        <label class="form-label small">Apellido</label>
                                        <input type="text" id="reg-apellido" class="form-control" required>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">Correo Electrónico</label>
                                    <input type="email" id="reg-email" class="form-control" required>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">DNI</label>
                                    <input type="number" id="reg-dni" class="form-control" required placeholder="Solo números">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small">Contraseña</label>
                                    <input type="password" id="reg-password" class="form-control" required placeholder="Mínimo 6 caracteres">
                                </div>
                                <button type="submit" class="btn btn-success w-100">Crear Cuenta Nueva</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="productoModal" tabindex="-1" aria-labelledby="productoModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title fw-bold" id="productoModalLabel">Gestionar Producto</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="form-producto" onsubmit="guardarProducto(event)">
                        <input type="hidden" id="prod-id"> 
                        <div class="mb-2">
                            <label class="form-label small">Nombre del Producto</label>
                            <input type="text" id="prod-nombre" class="form-control form-control-sm" required>
                        </div>
                        <div class="row mb-2">
                            <div class="col">
                                <label class="form-label small">Marca</label>
                                <input type="text" id="prod-marca" class="form-control form-control-sm" required>
                            </div>
                            <div class="col">
                                <label class="form-label small">Categoría</label>
                                <select id="prod-categoria" class="form-select form-select-sm" required>
                                    <option value="Componentes">Componentes</option>
                                    <option value="Periféricos">Periféricos</option>
                                    <option value="Celulares">Celulares</option>
                                </select>
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col">
                                <label class="form-label small">Precio ($)</label>
                                <input type="number" id="prod-precio" class="form-control form-control-sm" required>
                            </div>
                            <div class="col">
                                <label class="form-label small">Stock</label>
                                <input type="number" id="prod-stock" class="form-control form-control-sm" required>
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col">
                                <label class="form-label small">Garantía (Años)</label>
                                <input type="number" id="prod-garantia" class="form-control form-control-sm" min="0" max="50" required placeholder="Ej: 1">
                            </div>
                            <div class="col">
                                <label class="form-label small">Descuento (%)</label>
                                <input type="number" id="prod-descuento" class="form-control form-control-sm" value="0">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">URL de la Imagen</label>
                            <input type="text" id="prod-imagen" class="form-control form-control-sm" placeholder="/images/producto.png">
                        </div>
                        <button type="submit" class="btn btn-primary w-100 fw-bold">Guardar Cambios</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalCompraExitosa" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-success text-white border-0">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-bag-check-fill me-2"></i>¡Compra Exitosa!
                    </h5>
                </div>
                <div class="modal-body text-center py-4">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                    <h4 class="fw-bold mt-3">¡Gracias por tu compra!</h4>
                    <p class="text-muted">Tu pedido fue procesado correctamente.</p>
                    <div class="bg-light rounded p-3 my-3 text-start">
                        <p class="mb-1 small text-muted">Número de Factura</p>
                        <h5 class="fw-bold text-dark" id="modal-id-factura">#0000</h5>
                        <hr>
                        <p class="mb-1 small text-muted">Productos comprados</p>
                        <ul class="list-unstyled mb-0" id="modal-lista-productos"></ul>
                        <hr>
                        <p class="mb-1 small text-muted">Total abonado</p>
                        <h5 class="fw-bold text-success" id="modal-total-compra">$0</h5>
                    </div>
                </div>
                <div class="modal-footer border-0 justify-content-center">
                    <button type="button" class="btn btn-success fw-bold px-5" data-bs-dismiss="modal">
                        Finalizar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalConfirmarVaciar" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
             <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-danger text-white border-0">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Vaciar Carrito
                    </h5>
                </div>
                <div class="modal-body text-center py-3">
                    <p class="mb-0">¿Desea vaciar el carrito?</p>
                </div>
                <div class="modal-footer border-0 justify-content-center gap-2">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-danger btn-sm fw-bold" onclick="confirmarVaciarCarrito()">Sí, vaciar</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const contenedor = document.getElementById('catalogo-contenedor');
        let carrito = JSON.parse(localStorage.getItem('carrito')) || [];
        let paginaActual = 1;

        async function ejecutarLogin(event) {
            event.preventDefault();
            const email = document.getElementById('login-email').value;
            const password = document.getElementById('login-password').value;

            try {
                const respuesta = await fetch('http://localhost:3000/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });

                const data = await respuesta.json();
                
                if (!respuesta.ok) {
                    const toast = document.createElement('div');
                    toast.innerHTML = `
                        <div style="position:fixed; top:20px; right:20px; z-index:9999;">
                            <div class="toast show align-items-center text-white bg-danger border-0 shadow-lg" role="alert">
                                <div class="d-flex">
                                    <div class="toast-body fs-6">
                                        <i class="bi bi-x-circle-fill me-2"></i>
                                        ${data.error || "Datos incorrectos."} 
                                    </div>
                                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                                </div>
                            </div>
                        </div>`;
                    document.body.appendChild(toast);
                    setTimeout(() => toast.remove(), 3000);
                    return;
                }

                localStorage.setItem('token', data.token);
                localStorage.setItem('esAdmin', data.usuario.administrador); 
                localStorage.setItem('nombreUsuario', data.usuario.nombre); 
                
                const toast = document.createElement('div'); 
                toast.innerHTML = `
                    <div style="position:fixed; top:20px; right:20px; z-index:9999;">
                        <div class="toast show align-items-center text-white bg-dark border-0 shadow-lg" role="alert">
                            <div class="d-flex">
                                <div class="toast-body fs-6">
                                    <i class="bi bi-check-circle-fill text-success me-2"></i>
                                    ¡Bienvenido a <strong>NeoData Shop</strong>!
                                </div>
                                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                            </div>
                        </div>
                    </div>`;
                document.body.appendChild(toast);
                setTimeout(() => { toast.remove(); location.reload(); }, 1000); 

            } catch (error) {
                alert("Error de conexión al intentar iniciar sesión.");
            }
        }

        async function ejecutarRegistro(event) {
            event.preventDefault();
            const nombre = document.getElementById('reg-nombre').value;
            const apellido = document.getElementById('reg-apellido').value;
            const dni = document.getElementById('reg-dni').value;
            const email = document.getElementById('reg-email').value;
            const password = document.getElementById('reg-password').value;

            try {
                const respuesta = await fetch('http://localhost:3000/api/auth/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nombre, apellido, dni, email, password })
                });

                const data = await respuesta.json();
                if (!respuesta.ok) return alert(data.error || "Error al registrarse.");

                alert("¡Registro exitoso! Ya puedes iniciar sesión en la pestaña de Ingresar.");
                document.getElementById('form-registro').reset();
                
                const loginTab = new bootstrap.Tab(document.getElementById('login-tab'));
                loginTab.show();

            } catch (error) {
                alert("Error de conexión al intentar registrarse.");
            }
        }

        function verificarSesionUI() {
            const token = localStorage.getItem('token');
            const esAdmin = localStorage.getItem('esAdmin');
            const nombreUsuario = localStorage.getItem('nombreUsuario') || 'Usuario';
            const sessionContainer = document.getElementById('session-actions');
            const adminContainer = document.getElementById('admin-actions');

            if (token) {
                sessionContainer.innerHTML = `
                    <span class="text-white small me-3"><i class="bi bi-circle-fill text-success small me-1"></i> Bienvenido, <strong>${nombreUsuario}</strong>${esAdmin == '1' ? ' <span class="badge bg-warning text-dark ms-1">Admin</span>' : ''}</span>
                    <button class="btn btn-danger btn-sm" onclick="cerrarSesion()">Salir</button>
                `;

                if (esAdmin == '1' && adminContainer) {
                    adminContainer.innerHTML = `
                        <a class="btn btn-outline-info btn-sm d-flex align-items-center gap-1 me-2" href="/usuarios">
                            <i class="bi bi-people-fill fs-6"></i>
                            <span>Gestionar Usuarios</span>
                        </a>
                        <button class="btn btn-outline-success btn-sm d-flex align-items-center gap-1 me-2" onclick="abrirModalCrear()">
                            <i class="bi bi-plus-circle fs-6"></i>
                            <span>Nuevo Producto</span>
                        </button>
                        <button class="btn btn-outline-warning btn-sm d-flex align-items-center gap-1 me-3" onclick="descargarReporteCSV()">
                            <i class="bi bi-file-earmark-spreadsheet fs-6"></i>
                            <span>Reporte CSV</span>
                        </button>
                    `;
                }
            }
        }

        function cerrarSesion() {
            localStorage.removeItem('token');
            localStorage.removeItem('esAdmin');
            localStorage.removeItem('nombreUsuario');
            const toast = document.createElement('div');
            toast.innerHTML = `
                <div style="position:fixed; top:20px; right:20px; z-index:9999;">
                    <div class="toast show align-items-center text-white bg-dark border-0 shadow-lg" role="alert">
                        <div class="d-flex">
                            <div class="toast-body fs-6">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                Sesión cerrada.
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                        </div>
                    </div>
                </div>`;
            document.body.appendChild(toast);
            setTimeout(() => { toast.remove(); location.reload(); }, 1000);
        }

        async function descargarReporteCSV() {
            try {
                const token = localStorage.getItem('token'); 
                if (!token) {
                    alert("Acceso denegado.");
                    return;
                }

                const respuesta = await fetch('http://localhost:3000/api/reportes/productos', {
                    method: 'GET',
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (!respuesta.ok) {
                    if (respuesta.status === 403) alert("Error: No tienes permisos de Administrador.");
                    else alert("Error al generar el reporte.");
                    return;
                }

                const blob = await respuesta.blob();
                const urlDescarga = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = urlDescarga;
                a.download = "neodata_shop_productos.csv";
                document.body.appendChild(a);
                a.click();
                a.remove();
            } catch (error) {
                console.error(error);
                alert("Error al conectar con el servidor de reportes.");
            }
        }

        async function loadProducts(selectedCategory = "", page = 1) {
            try {
                paginaActual = page; 
                let url = `http://localhost:3000/api/productos?page=${page}&limit=4`;
                if (selectedCategory) {
                    url += `&categoria=${encodeURIComponent(selectedCategory)}`;
                }

                const token = localStorage.getItem('token');

                const respuesta = await fetch(url, {
                    method: 'GET',
                    headers: {
                        'Authorization': token ? `Bearer ${token}` : ''
                    }
                });
                
                const data = await respuesta.json();
                const productos = data.productos || [];
                
                contenedor.innerHTML = "";

                if (productos.length === 0) {
                    contenedor.innerHTML = `<div class="col-12 text-center text-muted mt-4"><h3>No se encontraron productos vigentes.</h3></div>`;
                    return;
                }

                const esAdmin = localStorage.getItem('esAdmin') == '1';

                productos.forEach(producto => {
                    const sinStock = producto.Stock <= 0;
                    const estaHabilitado = producto.Habilitado !== 0;

                    let botonesAccion = '';
                    if (esAdmin) {
                        const botonEstado = estaHabilitado 
                            ? `<button class="btn btn-secondary btn-sm flex-fill fw-bold" onclick="cambiarEstadoProducto(${producto.ID_Producto}, 'deshabilitar')">
                                    <i class="bi bi-eye-slash"></i> Deshabilitar
                               </button>`
                            : `<button class="btn btn-success btn-sm flex-fill fw-bold" onclick="cambiarEstadoProducto(${producto.ID_Producto}, 'habilitar')">
                                    <i class="bi bi-eye"></i> Habilitar
                               </button>`;

                        botonesAccion = `
                            <div class="d-flex gap-1">
                                <button class="btn btn-warning btn-sm flex-fill fw-bold text-dark" onclick="abrirModalEditar('${escape(JSON.stringify(producto))}')">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </button>
                                ${botonEstado}
                            </div>
                        `;
                    } else {
                        botonesAccion = `
                            <div class="d-grid">
                                <button class="btn btn-dark btn-sm" ${sinStock ? 'disabled' : ''} onclick="procesarSeleccion(${producto.ID_Producto}, '${producto.Nombre}', ${producto.Precio}, ${producto.Descuento || 0})">
                                    ${sinStock ? 'Sin Stock' : 'Añadir al carrito'}
                                </button>
                            </div>
                        `;
                    }

                    const badgeVisibilidad = esAdmin 
                        ? `<span class="badge ${estaHabilitado ? 'bg-success' : 'bg-dark'} small mb-2 d-inline-block">
                                ${estaHabilitado ? '<i class="bi bi-eye"></i> Catálogo Visible' : '<i class="bi bi-eye-slash"></i> Catálogo Oculto'}
                           </span>`
                        : '';

                    const cardHTML = `
                        <div class="col-12 col-md-6 col-lg-3 mb-4">
                            <div class="card h-100 shadow-sm card-dinamica ${sinStock || !estaHabilitado ? 'opacity-75' : ''}">
                                <img src="${producto.Ruta_Imagen || '/default.png'}" class="card-img-top p-2" alt="${producto.Nombre}" style="height: 200px; object-fit: contain;">
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title fw-bold">${producto.Nombre}</h5>
                                    
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <h6 class="text-primary fw-bold fs-5 m-0">$${Number(producto.Precio).toLocaleString()}</h6>
                                        ${producto.Descuento > 0 ? `<span class="badge bg-danger small">${producto.Descuento}% OFF</span>` : ''}
                                    </div>

                                    ${badgeVisibilidad}
                                    <p class="card-text text-muted small mb-1"><strong>Marca:</strong> ${producto.Marca || 'Genérica'}</p>
                                    <p class="card-text text-muted small mb-1"><strong>Categoría:</strong> ${producto.Category || 'General'}</p>
                                    <p class="card-text text-muted small mb-3"><strong>Garantía:</strong> ${producto.Garanty} ${producto.Garanty == 1 ? 'Año' : 'Años'}</p>
                                    
                                    <div class="mt-auto">
                                        <p class="small fw-bold ${sinStock ? 'text-danger' : 'text-success'} mb-2">
                                            ${sinStock ? 'Agotado' : `Stock: ${producto.Stock} u.`}
                                        </p>
                                        
                                        ${!esAdmin ? `
                                        <div class="mb-3 d-flex align-items-center gap-2">
                                            <label for="cant-${producto.ID_Producto}" class="small text-secondary text-nowrap">Cant:</label>
                                            <input type="number" id="cant-${producto.ID_Producto}" class="form-control form-control-sm text-center" value="1" min="1" max="${producto.Stock}" ${sinStock ? 'disabled' : ''} style="width: 70px;">
                                        </div>
                                        ` : ''}
                                        
                                        ${botonesAccion}
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                    contenedor.innerHTML += cardHTML;
                });

                const filaPaginacion = document.createElement('div');
                filaPaginacion.className = "col-12 d-flex justify-content-center align-items-center gap-3 mt-3 mb-5";
                filaPaginacion.innerHTML = `
                    <button class="btn btn-outline-dark btn-sm px-4" ${data.currentPage === 1 ? 'disabled' : ''} 
                        onclick="loadProducts('${selectedCategory}', ${data.currentPage - 1})">
                        <i class="bi bi-arrow-left me-1"></i> Anterior
                    </button>
                    <span class="fw-bold text-muted small">Página ${data.currentPage} de ${data.totalPages}</span>
                    <button class="btn btn-outline-dark btn-sm px-4" ${data.currentPage === data.totalPages ? 'disabled' : ''} 
                        onclick="loadProducts('${selectedCategory}', ${data.currentPage + 1})">
                        Siguiente <i class="bi bi-arrow-right ms-1"></i>
                    </button>
                `;
                contenedor.appendChild(filaPaginacion);
                actualizarInterfazCarrito();

            } catch (error) {
                console.error("Error en Fetch de Frontend:", error);
                contenedor.innerHTML = `<div class="col-12 text-center"><div class="alert alert-danger d-inline-block">Error al conectar con la API de NeoData Shop.</div></div>`;
            }
        }

        // 🌟 NUEVO: Setea los campos vacíos y la garantía entera en 1 año por defecto
        function abrirModalCrear() {
            document.getElementById('form-producto').reset();
            document.getElementById('prod-id').value = "";
            document.getElementById('prod-garantia').value = "1"; // 1 Año por defecto
            document.getElementById('productoModalLabel').innerText = "Nuevo Producto";
            
            const modal = new bootstrap.Modal(document.getElementById('productoModal'));
            modal.show();
        }

        // 🌟 NUEVO: Mapea los valores directos sin el tratamiento de strings de fechas (.split)
        function abrirModalEditar(productoEscapeado) {
            const producto = JSON.parse(unescape(productoEscapeado));
            
            document.getElementById('prod-id').value = producto.ID_Producto;
            document.getElementById('prod-nombre').value = producto.Nombre;
            document.getElementById('prod-marca').value = producto.Marca;
            document.getElementById('prod-categoria').value = producto.Category;
            document.getElementById('prod-precio').value = producto.Precio;
            document.getElementById('prod-stock').value = producto.Stock;
            document.getElementById('prod-garantia').value = producto.Garanty; // Setea el número directamente
            document.getElementById('prod-descuento').value = producto.Descuento;
            document.getElementById('prod-imagen').value = producto.Ruta_Imagen || "";
            
            document.getElementById('productoModalLabel').innerText = "Editar Producto";
            
            const modal = new bootstrap.Modal(document.getElementById('productoModal'));
            modal.show();
        }

        async function guardarProducto(event) {
            event.preventDefault();
            const id = document.getElementById('prod-id').value;
            const token = localStorage.getItem('token');

            // 🌟 NUEVO: Recolecta Garanty como un entero nativo
            const payload = {
                Nombre: document.getElementById('prod-nombre').value,
                Marca: document.getElementById('prod-marca').value,
                Category: document.getElementById('prod-categoria').value,
                Precio: parseFloat(document.getElementById('prod-precio').value),
                Stock: parseInt(document.getElementById('prod-stock').value),
                Garanty: parseInt(document.getElementById('prod-garantia').value), 
                Descuento: parseInt(document.getElementById('prod-descuento').value),
                Ruta_Imagen: document.getElementById('prod-imagen').value
            };

            const url = id ? `http://localhost:3000/api/productos/${id}` : 'http://localhost:3000/api/productos';
            const method = id ? 'PUT' : 'POST';

            try {
                const respuesta = await fetch(url, {
                    method: method,
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify(payload)
                });

                const data = await respuesta.json();
                if (!respuesta.ok) throw new Error(data.error || "No se pudo guardar el producto.");

                alert(data.mensaje);
                
                const modalElement = document.getElementById('productoModal');
                const modalInstance = bootstrap.Modal.getInstance(modalElement) || new bootstrap.Modal(modalElement);
                modalInstance.hide();
                
                loadProducts(document.getElementById('category-filter').value, paginaActual);

            } catch (error) {
                alert(error.message);
            }
        }

        async function cambiarEstadoProducto(id, accion) {
            const mensajeConfirmacion = accion === 'habilitar'
                ? "¿Deseas habilitar este producto para que sea visible en el catálogo de clientes?"
                : "¿Deseas deshabilitar este producto? Se ocultará del catálogo general.";

            if (!confirm(mensajeConfirmacion)) return;
            
            const token = localStorage.getItem('token');
            try {
                const respuesta = await fetch(`http://localhost:3000/api/productos/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                const data = await respuesta.json();
                if(!respuesta.ok) throw new Error(data.error || `No se pudo ${accion} el producto`);

                alert(data.mensaje);
                loadProducts(document.getElementById('category-filter').value, paginaActual); 
                
            } catch (error) {
                alert(error.message);
            }
        }

        // --- Lógica Carrito de Compras ---
        function procesarSeleccion(id, nombre, precio, descuento = 0) {
            const inputCant = document.getElementById(`cant-${id}`);
            const cantidad = inputCant ? parseInt(inputCant.value) : 1;

            const itemExistente = carrito.find(item => item.id === id);
            if (itemExistente) {
                itemExistente.cantidad += cantidad;
                itemExistente.descuento = descuento;
            } else {
                carrito.push({ id, nombre, precio, cantidad, descuento });
            }

            localStorage.setItem('carrito', JSON.stringify(carrito));
            actualizarInterfazCarrito();
            
            if(inputCant) inputCant.value = 1;
        }

        function obtenerCuponCarrito() {
            const inputCupon = document.getElementById('cupon-carrito');
            const valorCupon = inputCupon ? inputCupon.value.trim() : "";

            if (valorCupon === "") return { id: 0, descuento: null };
            if (valorCupon === "1") return { id: 1, descuento: 20 };
            if (valorCupon === "2") return { id: 2, descuento: 15 };

            return { invalido: true };
        }

        function actualizarInterfazCarrito() {
            const contador = document.getElementById('contador-carrito');
            const listaVacia = document.getElementById('lista-carrito-vacia');
            const listaProductos = document.getElementById('lista-carrito-productos');
            const totalElemento = document.getElementById('total-carrito');
            const btnVaciar = document.getElementById('btn-vaciar');
            const btnPagar = document.getElementById('btn-pagar');

            const totalItems = carrito.reduce((sum, item) => sum + item.cantidad, 0);
            contador.innerText = totalItems;

            if (carrito.length === 0) {
                listaVacia.classList.remove('d-none');
                listaProductos.classList.add('d-none');
                listaProductos.innerHTML = "";
                totalElemento.innerText = "$0";
                btnVaciar.setAttribute('disabled', 'true');
                btnPagar.setAttribute('disabled', 'true');
            } else {
                listaVacia.classList.add('d-none');
                listaProductos.classList.remove('d-none');
                listaProductos.innerHTML = "";

                const cupon = obtenerCuponCarrito();
                const tieneCuponValido = cupon.descuento !== null && !cupon.invalido;
                let sumaTotal = 0;
                let totalSinDescuentos = 0;
                carrito.forEach(item => {
                    const subtotalSinDescuento = item.precio * item.cantidad;
                    const descuentoProducto = Number(item.descuento || 0);
                    const subtotal = tieneCuponValido
                        ? subtotalSinDescuento
                        : subtotalSinDescuento * (1 - descuentoProducto / 100);
                    const textoDescuento = !tieneCuponValido && descuentoProducto > 0 ? ` - ${descuentoProducto}% OFF` : '';

                    totalSinDescuentos += subtotalSinDescuento;
                    sumaTotal += subtotal;

                    listaProductos.innerHTML += `
                        <li class="list-group-item d-flex justify-content-between align-items-center small">
                            <div>
                                <span class="fw-bold text-dark">${item.nombre}</span>
                                <br>
                                <span class="text-muted">$${Number(item.precio).toLocaleString()} x ${item.cantidad}${textoDescuento}</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-bold text-primary">$${Math.round(subtotal).toLocaleString()}</span>
                                <button class="btn btn-sm btn-outline-danger p-1 py-0" onclick="eliminarItemIndividual(${item.id})">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        </li>
                    `;
                });

                if (tieneCuponValido) {
                    sumaTotal = totalSinDescuentos * (1 - cupon.descuento / 100);
                }

                totalElemento.innerText = `$${Math.round(sumaTotal).toLocaleString()}`;
                btnVaciar.removeAttribute('disabled');
                btnPagar.removeAttribute('disabled');
            }
        }

        function eliminarItemIndividual(id) {
            carrito = carrito.filter(item => item.id !== id);
            localStorage.setItem('carrito', JSON.stringify(carrito));
            actualizarInterfazCarrito();
        }

        function abrirModalConfirmarVaciar() {
            const modalVaciar = new bootstrap.Modal(document.getElementById('modalConfirmarVaciar'));
            modalVaciar.show();
        }

        function confirmarVaciarCarrito() {
            carrito = [];
            localStorage.removeItem('carrito');
            actualizarInterfazCarrito();
            bootstrap.Modal.getInstance(document.getElementById('modalConfirmarVaciar')).hide();
        }

        async function enviarCheckout() {
            const token = localStorage.getItem('token');
            if (!token) {
                alert("Debes iniciar sesión con tu cuenta para procesar una compra.");
                bootstrap.Modal.getInstance(document.getElementById('modalCarrito')).hide();
                new bootstrap.Modal(document.getElementById('authModal')).show();
                return;
            }

            const medioPago = document.getElementById('medio-pago').value;
            const cupon = obtenerCuponCarrito();
            if (cupon.invalido) {
                alert("Cupon Invalido");
                return;
            }

            const productosPayload = carrito.map(item => ({
                ID_Producto: item.id,
                Cantidad: item.cantidad
            }));

            try {
                const respuesta = await fetch('http://localhost:3000/api/productos/checkout', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        ID_MedioPago: parseInt(medioPago),
                        ID_Cupon: cupon.id,
                        productos: productosPayload
                    })
                });

                const data = await respuesta.json();
                if (!respuesta.ok) throw new Error(data.error || "Ocurrió un problema al procesar la facturación.");

                bootstrap.Modal.getInstance(document.getElementById('modalCarrito')).hide();

                document.getElementById('modal-id-factura').innerText = `#${data.id_factura}`;
                document.getElementById('modal-total-compra').innerText = `$${Number(data.total).toLocaleString()}`;
                
                const ulLista = document.getElementById('modal-lista-productos');
                ulLista.innerHTML = "";
                carrito.forEach(item => {
                    ulLista.innerHTML += `<li class="small text-muted"><i class="bi bi-caret-right-fill text-success me-1"></i>${item.nombre} (x${item.cantidad})</li>`;
                });

                carrito = [];
                localStorage.removeItem('carrito');
                actualizarInterfazCarrito();

                const modalExito = new bootstrap.Modal(document.getElementById('modalCompraExitosa'));
                modalExito.show();

                loadProducts(document.getElementById('category-filter').value, paginaActual);

            } catch (error) {
                alert(error.message);
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            verificarSesionUI();
            document.getElementById('cupon-carrito').addEventListener('input', actualizarInterfazCarrito);
            const filterValue = document.getElementById('category-filter').value;
            loadProducts(filterValue, 1);
        });
    </script>
</body>
</html>
