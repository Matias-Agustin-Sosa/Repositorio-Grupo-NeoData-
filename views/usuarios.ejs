<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NeoData Shop - Gestión de Usuarios</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">NeoData Shop</a>
            <div class="ms-auto">
                <a href="/" class="btn btn-outline-light btn-sm"><i class="bi bi-arrow-left"></i> Volver al Catálogo</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="card shadow-sm p-4 bg-white">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="fw-bold m-0 text-dark"><i class="bi bi-people"></i> Control de Usuarios / Clientes</h2>
                <button class="btn btn-primary fw-bold" onclick="abrirModalCrear()"><i class="bi bi-person-plus"></i> Registrar Usuario</button>
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle border">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Nombre Completo</th>
                            <th>DNI</th>
                            <th>Email</th>
                            <th>Rol</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="tabla-usuarios-body">
                        </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="modal fade" id="usuarioModal" tabindex="-1" aria-labelledby="usuarioModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title fw-bold" id="usuarioModalLabel">Gestionar Usuario</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="form-usuario" onsubmit="guardarUsuario(event)">
                        <input type="hidden" id="user-id">
                        <div class="row mb-2">
                            <div class="col">
                                <label class="form-label small fw-bold">Nombre</label>
                                <input type="text" id="user-nombre" class="form-control form-control-sm" required>
                            </div>
                            <div class="col">
                                <label class="form-label small fw-bold">Apellido</label>
                                <input type="text" id="user-apellido" class="form-control form-control-sm" required>
                            </div>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-bold">DNI</label>
                            <input type="text" id="user-dni" class="form-control form-control-sm" required>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-bold">Email</label>
                            <input type="email" id="user-email" class="form-control form-control-sm" required>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-bold">Contraseña</label>
                            <input type="password" id="user-password" class="form-control form-control-sm" placeholder="Nueva o actual contraseña">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Rol del Usuario</label>
                            <select id="user-admin" class="form-select form-select-sm" required>
                                <option value="0">Cliente (Usuario Regular)</option>
                                <option value="1">Administrador</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-dark w-100 fw-bold">Guardar Cambios</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const token = localStorage.getItem('token');
        const esAdmin = localStorage.getItem('esAdmin');

        // Impedir el ingreso si no posee credenciales administrativas válidas
        if (!token || esAdmin !== '1') {
            alert("Acceso denegado. Solo administradores.");
            window.location.href = "/";
        }

        // Cargar los usuarios en la tabla al iniciar
        async function cargarUsuarios() {
            try {
                const res = await fetch('http://localhost:3000/api/usuarios', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if(!res.ok) throw new Error("No se pudieron obtener los datos.");
                
                const usuarios = await res.json();
                const tbody = document.getElementById('tabla-usuarios-body');
                tbody.innerHTML = '';

                usuarios.forEach(u => {
                    tbody.innerHTML += `
                        <tr>
                            <td><strong>#${u.ID_Usuario}</strong></td>
                            <td>${u.Nombre} ${u.Apellido}</td>
                            <td>${u.DNI}</td>
                            <td>${u.Email}</td>
                            <td>
                                <span class="badge ${u.administrador === 1 ? 'bg-danger' : 'bg-secondary'}">
                                    ${u.administrador === 1 ? 'Admin' : 'Cliente'}
                                </span>
                            </td>
                            <td class="text-center">
                                <button class="btn btn-warning btn-sm fw-bold me-1 text-dark" onclick="abrirModalEditar('${escape(JSON.stringify(u))}')">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </button>
                                <button class="btn btn-danger btn-sm fw-bold" onclick="eliminarUsuario(${u.ID_Usuario})">
                                    <i class="bi bi-trash3"></i> Borrar
                                </button>
                            </td>
                        </tr>
                    `;
                });
            } catch (error) {
                alert(error.message);
            }
        }

        function abrirModalCrear() {
            document.getElementById('form-usuario').reset();
            document.getElementById('user-id').value = '';
            document.getElementById('user-password').required = true; // Obligatorio para usuarios nuevos
            document.getElementById('usuarioModalLabel').innerText = "Registrar Usuario";
            new bootstrap.Modal(document.getElementById('usuarioModal')).show();
        }

        function abrirModalEditar(objetoEscapado) {
            const u = JSON.parse(unescape(objetoEscapado));
            document.getElementById('user-id').value = u.ID_Usuario;
            document.getElementById('user-nombre').value = u.Nombre;
            document.getElementById('user-apellido').value = u.Apellido;
            document.getElementById('user-dni').value = u.DNI;
            document.getElementById('user-email').value = u.Email;
            
            // 🌟 Asegúrate de que diga 'u.administrador' en minúsculas:
            document.getElementById('user-admin').value = u.administrador; 
            
            document.getElementById('user-password').required = false; 
            document.getElementById('user-password').value = '';

            document.getElementById('usuarioModalLabel').innerText = "Editar Usuario";
            new bootstrap.Modal(document.getElementById('usuarioModal')).show();
        }

        async function guardarUsuario(event) {
            event.preventDefault();
            const id = document.getElementById('user-id').value;

            const payload = {
                Nombre: document.getElementById('user-nombre').value,
                Apellido: document.getElementById('user-apellido').value,
                DNI: document.getElementById('user-dni').value,
                Email: document.getElementById('user-email').value,
                Administrador: document.getElementById('user-admin').value,
                Password: document.getElementById('user-password').value
            };

            const url = id ? `http://localhost:3000/api/usuarios/${id}` : 'http://localhost:3000/api/usuarios';
            const method = id ? 'PUT' : 'POST';

            try {
                const res = await fetch(url, {
                    method,
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                if(!res.ok) throw new Error(data.error || "Error en el guardado");

                alert(data.mensaje);
                bootstrap.Modal.getInstance(document.getElementById('usuarioModal')).hide();
                cargarUsuarios();
            } catch (error) {
                alert(error.message);
            }
        }

        async function eliminarUsuario(id) {
            if(!confirm("¿Deseas dar de baja a este usuario permanentemente?")) return;
            try {
                const res = await fetch(`http://localhost:3000/api/usuarios/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const data = await res.json();
                if(!res.ok) throw new Error(data.error || "No se pudo eliminar");

                alert(data.mensaje);
                cargarUsuarios();
            } catch (error) {
                alert(error.message);
            }
        }

        // Carga automática inicial
        document.addEventListener('DOMContentLoaded', cargarUsuarios);
    </script>
</body>
</html>